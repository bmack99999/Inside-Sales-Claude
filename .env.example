# Copy this to .env and fill in your values
# Never commit .env to git

# Railway Postgres URL (set automatically by Railway in production)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Secret key for Flask sessions
SECRET_KEY=change-me-to-a-random-string

# API key used by extraction scripts to POST data to the dashboard
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
INGEST_API_KEY=change-me-to-a-random-string

# URL of the deployed dashboard (used by extraction scripts)
# DASHBOARD_URL=https://your-app.up.railway.app
# For local testing: DASHBOARD_URL=http://localhost:5000
DASHBOARD_URL=http://localhost:5000
